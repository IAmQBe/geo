          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Bot Errors",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(bot_errors_total[5m]))",
          "refId": "A"
        }
      ]
    }
  ]
}
